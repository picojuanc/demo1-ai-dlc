{
  "name": "demo1-ai-dlc",
  "version": "0.1.0",
  "private": true,
  "description": "Calendario de eventos personal con persistencia local — demo del methodology AI-DLC",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
